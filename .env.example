# H2S_DEMUCS_MODEL=htdemucs
# Legacy (pipeline ignores; task checkbox gates): H2S_EXPERIMENTAL_TWO_STEM_SEPARATION=false

# Gateway-first LLM (placeholders only; do not put provider keys in browser)
